# ======================================
# CONFIGURATION TEMPLATE (NE PAS MODIFIER)
# Copier vers .env.local pour développement
# ======================================

# Database (DEV: localhost | PROD: Railway fournit)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gaspass_db
DB_USER=postgres
DB_PASSWORD=your_dev_password

# Server (DEV: localhost | PROD: api.gaspass.store)
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# JWT (Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRE=7d

# Stripe (DEV: sk_test_ | PROD: sk_live_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_ADMIN_GROUP_ID=-1001234567890
TELEGRAM_WEBHOOK_URL=https://api.gaspass.store/api/telegram/webhook

# Admin Credentials (Générer depuis les scripts ou via UI)
ADMIN_EMAIL=admin@gaspass.store
ADMIN_PASSWORD=ChangeThisVeryStrongPassword123!
SEED_ADMIN_EMAIL=superadmin@gaspass.store
SEED_ADMIN_PASSWORD=ChangeThisSuperAdminPassword456!

# Email (Optional - for future email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=./uploads
